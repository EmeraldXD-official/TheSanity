	EvilBelt: {
		Tooltip:
			'''
			Reduce Damage taken by 17%
			Has a chance to Dodge Enemy attack
			Can Dash Trough Enemy

			"The Power of Evil is in Your Hand Now"
			'''
		DisplayName: Evil Belt
	}

	RoyalBonePack: {
		Tooltip:
			'''
			Increases the strength of friendly bees
			Shoots crossbones at enemies while you are attacking
			Summons shadow hands to attack your foes
			Slimes become friendly (except Explosive Attack from Slimes)

			Summons a special minion depending on your weapon class:
			[c/076AA8:Crowny Slime] (Melee)
			Summons a slime that slams into enemies, spawning homing spikes that inflict Slimed and On Fire!
			[c/A85707:Baby Net] (Ranger)
			Summons a mini Hornet that locks onto enemies, does a backflip, and fires 10 homing stingers that inflict Poisoned
			[c/595959:Blizzardnado] (Mage)
			Summons a mini tornado that throws rocks at enemies; fires a 15-rock barrage after every 5 shots, inflicting Frostburn
			[c/B5B5B5:Skullytron] (Summon)
			Summons a mini Skeletron head that locks onto enemies and throws 10 bones that return to the skull, inflicting Broken Armor
			"The Spirit of the Guardian now in your Soul"
			'''
		DisplayName: Royal Bone Pack
	}

	MechanicalCamera: {
		Tooltip:
			'''
			Increases defense by 15, damage reduction by 5%, and knockback resistance by 20%
			Provides immunity to Cursed Inferno and Ichor
			Your attacks have a 30% chance to inflict Cursed Inferno and Ichor
			Your attacks have a 10% chance to summon mini Twins to fight for you
			"Smile for the camera, the mechanical eyes are watching your every move"
			'''
		DisplayName: Mechanical Camera
	}

	MightyEagleSardine: {
		Tooltip: "[c/864A0E:Created By:] [c/860E0E:Izhar]"
		DisplayName: Mighty Eagle Sardine
	}

	TwinkleRelic: {
		Tooltip: ""
		DisplayName: Twinkle Relic
	}

	StarShineStaff: {
